# Copie este arquivo para .env e ajuste os valores conforme o ambiente.

# Chave secreta do Django. Em producao, gere uma chave forte e nao versione.
DJANGO_SECRET_KEY=troque-esta-chave-em-producao

# True em desenvolvimento, False em producao.
DJANGO_DEBUG=True

# Hosts permitidos, separados por virgula.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Futura migracao para PostgreSQL/Neon. Nao usado nesta fase (SQLite local).
# DATABASE_URL=postgres://usuario:senha@host:5432/sobreaviso
